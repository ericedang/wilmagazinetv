# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# STRIPE_SECRET_KEY: Private key for Stripe API (Server-side only)
STRIPE_SECRET_KEY=
# VITE_STRIPE_PUBLISHABLE_KEY: Public key for Stripe.js (Client-side)
VITE_STRIPE_PUBLISHABLE_KEY=

# Flutterwave (African Payments: Orange Money, MTN, Bank Transfer)
VITE_FLW_PUBLIC_KEY=
FLW_SECRET_KEY=

# MMGate Mobile Money Integration
MMGATE_URL=https://www.mmgate.org/mmgweb/
MMGATE_PARTNER_CODE=VOTRE_CODE_PARTENAIRE
MMGATE_USER=VOTRE_UTILISATEUR_API
MMGATE_PASSWORD=VOTRE_MOT_DE_PASSE
MMGATE_PARTNER_TOKEN=VOTRE_TOKEN_PARTENAIRE_API
