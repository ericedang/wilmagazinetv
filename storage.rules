rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /uploads/{allPaths=**} {
      // Autoriser la lecture publique
      allow read: if true;
      // Autoriser l'écriture seulement aux utilisateurs authentifiés
      // Idéalement, on vérifierait le rôle admin ici aussi
      allow write: if request.auth != null && request.resource.size < 10 * 1024 * 1024;
    }
    match /files/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.resource.size < 50 * 1024 * 1024;
    }
  }
}
